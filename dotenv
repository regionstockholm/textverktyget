# AI Service Configuration
GEMINI_API_KEY=[gemini_api_key]
GEMINI_QE_API_KEY=[gemini_api_key-for-quality-evaluation]
AI_PROVIDER=gemini-2.5-flash

# OpenAI Service Configuration
OPENAI_API_KEY=[open_ai_api]

# Application Configuration
PORT=3000
# Change admin key to a secure password if more than one user
ADMIN_API_KEY=admin
# Random string, needed to keep stored data safe and encrypted (use sha256 key for example)
# Set for convenince, change if not running local
CONFIG_MASTER_KEY=LaNg5Ch1K09BXqXNRlczqFnG9OqFp2gX

# Other Configuration
DEEPL_API_KEY=[deepl_api-not-used-atm]

# Database Configuration (Postgres)
# Docker compose (service): postgresql://textverktyg:textverktyg@postgres:5432/textverktyg
# Local dev (host): postgresql://textverktyg:textverktyg@localhost:5432/textverktyg
DATABASE_URL=postgresql://textverktyg:textverktyg@postgres:5432/textverktyg
# Optional: use a different URL for local test runs (non-Docker)
TEST_DATABASE_URL=postgresql://textverktyg:textverktyg@localhost:5432/textverktyg
# Set to "require" for Azure Postgres, "disable" for local
DATABASE_SSL_MODE=disable
# Optional: set to "false" when using managed certs
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Runtime throughput and quality flow tuning
# Group isolation (one deployment/group keyspace)
GROUP_ID=default
# Admin auth brute-force protection
ADMIN_AUTH_RATE_LIMIT_WINDOW_MS=600000
ADMIN_AUTH_RATE_LIMIT_MAX=20
# Optional shared limiter backend (recommended for multi-instance groups)
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_KEY_PREFIX=textverktyg:rate_limit
# Global API limiter (/api and /upload)
API_GLOBAL_RATE_LIMIT_WINDOW_MS=900000
API_GLOBAL_RATE_LIMIT_MAX=100
# Route-specific API limiters
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_STANDARD_MAX=30
API_RATE_LIMIT_PROGRESS_MAX=240
API_RATE_LIMIT_SUMMARIZE_MAX=10
API_RATE_LIMIT_QUALITY_MAX=10
API_RATE_LIMIT_FILE_UPLOAD_MAX=5
# AI provider RPM limits
GEMINI_RPM_LIMIT=10
OPENAI_RPM_LIMIT=1000
# Summarization chunking and upload request limits
MAX_TEXT_CHUNKS=10
MAX_FILES_PER_UPLOAD=1
# Summarize queue and backpressure
SUMMARIZE_MAX_CONCURRENT_JOBS=8
SUMMARIZE_MAX_QUEUE_SIZE=200
SUMMARIZE_MAX_QUEUE_WAIT_MS=45000
SUMMARIZE_SHARED_TOKEN_TTL_MS=900000
SUMMARIZE_RETRY_AFTER_SECONDS=15
# Optional separate Redis/key prefix for summarize queue coordination
SUMMARIZE_QUEUE_REDIS_URL=
SUMMARIZE_QUEUE_KEY_PREFIX=textverktyg:summarize_queue
# Provider circuit breaker
PROVIDER_FALLBACK_ENABLED=true
PROVIDER_CB_FAILURE_THRESHOLD=5
PROVIDER_CB_COOLDOWN_MS=30000

# Pipeline v2 flags are deprecated in v0.1.0 (pipeline v2 path is always on)
LIMITER_SHARED_ENABLED=true

# Default config source (optional)
# Relative paths resolve from project root. Default: config/default-config.json
DEFAULT_CONFIG_JSON_PATH=config/default-config.json

# Web fetch security limits
URL_FETCH_TIMEOUT_MS=10000
URL_FETCH_MAX_REDIRECTS=3
URL_FETCH_MAX_RESPONSE_BYTES=2097152
# Keep false unless you explicitly need internal network fetches
URL_FETCH_ALLOW_PRIVATE_NETWORK=false
